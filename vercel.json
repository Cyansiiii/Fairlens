{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "functions": {
    "backend/**": {
      "excludeFiles": "{node_modules,**/__pycache__}/**"
    }
  }
}

# =============================================================================
# FairLens — Environment Variables
# =============================================================================

# App Mode
FAIRLENS_DEV_MODE=true

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY_JSON=

# Google Cloud
GCP_PROJECT_ID=
GCS_BUCKET_NAME=fairlens-uploads
BIGQUERY_DATASET_ID=fairlens_audit_trail
VERTEX_AI_LOCATION=us-central1

# Gemini / Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:5173,https://fairlens.vercel.app

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
